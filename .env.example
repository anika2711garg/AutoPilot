# ─── Database (Neon cloud Postgres) ──────────────────────────────────────────
# Two strings: DIRECT (engine + migrations, unpooled) and POOLED (web queries).
# Neon dashboard → Connection string. The POOLED host contains "-pooler";
# DIRECT is the same string without it. If unsure, use the same string for both
# to start — it works, just not optimally.
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL_POOLED=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# ─── E2B cloud sandbox ───────────────────────────────────────────────────────
# e2b.dev → Dashboard → API Keys. Never enters a prompt or the sandbox repo.
E2B_API_KEY=

# ─── LLM routing (via OpenRouter) ────────────────────────────────────────────
# Never enters the sandbox, a prompt built from untrusted text, or the repo.
OPENROUTER_API_KEY=
LLM_MODEL_STRONG=anthropic/claude-opus-4.8
LLM_MODEL_CHEAP=anthropic/claude-haiku-4.5

# ─── GitHub (fine-grained PAT, scoped to test repos only) ────────────────────
# contents:RW, pull_requests:RW, issues:R. Never a classic full-scope PAT.
# Engine env only — never in the sandbox.
GITHUB_TOKEN=

# ─── Run budgets (hard ceilings enforced by the orchestrator) ────────────────
BUDGET_USD_PER_RUN=2.00
MAX_ATTEMPTS=3
WALL_CLOCK_SECONDS=1800

# ─── Strictness: strict | permissive | vibes ─────────────────────────────────
DEFAULT_MODE=permissive

# ─── Kill switch: false disables ALL GitHub writes instantly ─────────────────
GITHUB_WRITES_ENABLED=true
